PORT=4000
NODE_ENV=development

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/ac_manager

# JWT
JWT_SECRET=change_this_to_a_long_random_secret_minimum_32_chars
JWT_EXPIRES_IN=7d

# Agent shared secret (all agents must send this header)
AGENT_SECRET=change_this_agent_secret

# Daily report cron (default: midnight)
REPORT_CRON=0 0 * * *
