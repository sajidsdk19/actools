<Application x:Class="AcAgent.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Application.Resources>

        <!-- ═══ Color Palette ═══ -->
        <Color x:Key="BgDeepColor">#FF0A0A15</Color>
        <Color x:Key="BgPanelColor">#FF111128</Color>
        <Color x:Key="BgCardColor">#FF1A1A35</Color>
        <Color x:Key="BgHoverColor">#FF22224A</Color>
        <Color x:Key="AccentColor">#FFFF4757</Color>
        <Color x:Key="AccentGoldColor">#FFFFA502</Color>
        <Color x:Key="SuccessColor">#FF2ED573</Color>
        <Color x:Key="TextPrimaryColor">#FFE8E8F5</Color>
        <Color x:Key="TextSecondaryColor">#FF7878A8</Color>
        <Color x:Key="BorderColor">#FF2A2A50</Color>
        <Color x:Key="SelectedBgColor">#33FF4757</Color>

        <SolidColorBrush x:Key="BgDeep"        Color="{StaticResource BgDeepColor}"/>
        <SolidColorBrush x:Key="BgPanel"       Color="{StaticResource BgPanelColor}"/>
        <SolidColorBrush x:Key="BgCard"        Color="{StaticResource BgCardColor}"/>
        <SolidColorBrush x:Key="BgHover"       Color="{StaticResource BgHoverColor}"/>
        <SolidColorBrush x:Key="Accent"        Color="{StaticResource AccentColor}"/>
        <SolidColorBrush x:Key="AccentGold"    Color="{StaticResource AccentGoldColor}"/>
        <SolidColorBrush x:Key="Success"       Color="{StaticResource SuccessColor}"/>
        <SolidColorBrush x:Key="TextPrimary"   Color="{StaticResource TextPrimaryColor}"/>
        <SolidColorBrush x:Key="TextSecondary" Color="{StaticResource TextSecondaryColor}"/>
        <SolidColorBrush x:Key="Border"        Color="{StaticResource BorderColor}"/>
        <SolidColorBrush x:Key="SelectedBg"    Color="{StaticResource SelectedBgColor}"/>
        <SolidColorBrush x:Key="Transparent"   Color="Transparent"/>

        <!-- ═══ Typography ═══ -->
        <FontFamily x:Key="MainFont">Segoe UI</FontFamily>

        <!-- ═══ ScrollBar Style ═══ -->
        <Style x:Key="DarkScrollBar" TargetType="ScrollBar">
            <Setter Property="Background"  Value="Transparent"/>
            <Setter Property="Width"       Value="6"/>
        </Style>
        <Style TargetType="ScrollViewer">
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <!-- ═══ Search TextBox ═══ -->
        <Style x:Key="SearchBox" TargetType="TextBox">
            <Setter Property="Background"       Value="#1A1A35"/>
            <Setter Property="Foreground"       Value="{StaticResource TextPrimary}"/>
            <Setter Property="BorderBrush"      Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Padding"          Value="8,6"/>
            <Setter Property="FontSize"         Value="13"/>
            <Setter Property="FontFamily"       Value="{StaticResource MainFont}"/>
            <Setter Property="CaretBrush"       Value="{StaticResource Accent}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <Grid>
                                <TextBlock x:Name="placeholder"
                                           Text="{TemplateBinding Tag}"
                                           Foreground="{StaticResource TextSecondary}"
                                           Margin="10,6"
                                           FontSize="13"
                                           IsHitTestVisible="False"
                                           Visibility="Collapsed"/>
                                <ScrollViewer x:Name="PART_ContentHost" Margin="4,2"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="placeholder" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{StaticResource Accent}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ List Item Style ═══ -->
        <Style x:Key="ListItem" TargetType="ListBoxItem">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{StaticResource TextPrimary}"/>
            <Setter Property="Padding"         Value="10,7"/>
            <Setter Property="Margin"          Value="0,1"/>
            <Setter Property="FontSize"        Value="12.5"/>
            <Setter Property="FontFamily"      Value="{StaticResource MainFont}"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource BgHover}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource SelectedBg}"/>
                                <Setter Property="Foreground" Value="{StaticResource Accent}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ ListBox Style ═══ -->
        <Style x:Key="DarkListBox" TargetType="ListBox">
            <Setter Property="Background"       Value="Transparent"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="ItemContainerStyle" Value="{StaticResource ListItem}"/>
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
        </Style>

        <!-- ═══ ComboBox Style ═══ -->
        <Style x:Key="DarkCombo" TargetType="ComboBox">
            <Setter Property="Background"      Value="#1A1A35"/>
            <Setter Property="Foreground"      Value="#111111"/>

            <Setter Property="BorderBrush"     Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="10,7"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontFamily"      Value="{StaticResource MainFont}"/>
            <Setter Property="Height"          Value="38"/>
            <!-- Force dropdown items to use black text on white background -->
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="#111111"/>
                        <Setter Property="Background" Value="White"/>
                        <Setter Property="FontSize"   Value="13"/>
                        <Setter Property="Padding"    Value="10,6"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FDECEA"/>
                                <Setter Property="Foreground" Value="#C0392B"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#FDECEA"/>
                                <Setter Property="Foreground" Value="#C0392B"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ Launch Button ═══ -->
        <Style x:Key="LaunchButton" TargetType="Button">
            <Setter Property="Background"  Value="{StaticResource Accent}"/>
            <Setter Property="Foreground"  Value="White"/>
            <Setter Property="FontSize"    Value="15"/>
            <Setter Property="FontWeight"  Value="Bold"/>
            <Setter Property="FontFamily"  Value="{StaticResource MainFont}"/>
            <Setter Property="Height"      Value="52"/>
            <Setter Property="Cursor"      Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="10"
                                Padding="10">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#FF3A4060"/>
                                <Setter TargetName="bd" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.7"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ Secondary Button ═══ -->
        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource LaunchButton}">
            <Setter Property="Background"  Value="#FF2A2A50"/>
            <Setter Property="FontSize"    Value="13"/>
            <Setter Property="Height"      Value="42"/>
        </Style>

        <!-- ═══ Danger Button ═══ -->
        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource LaunchButton}">
            <Setter Property="Background"  Value="#FFCC2A3A"/>
            <Setter Property="FontSize"    Value="14"/>
            <Setter Property="Height"      Value="46"/>
        </Style>

        <!-- ═══ Slider Style ═══ -->
        <Style x:Key="DarkSlider" TargetType="Slider">
            <Setter Property="Foreground"  Value="{StaticResource Accent}"/>
            <Setter Property="Background"  Value="{StaticResource Border}"/>
            <Setter Property="Height"      Value="22"/>
        </Style>

        <!-- ═══ Section Header ═══ -->
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="Foreground"   Value="{StaticResource TextSecondary}"/>
            <Setter Property="FontSize"     Value="11"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="FontFamily"   Value="{StaticResource MainFont}"/>
            <Setter Property="Margin"       Value="0,0,0,6"/>
        
        </Style>

        <!-- ═══ ProgressBar ═══ -->
        <Style x:Key="TimerBar" TargetType="ProgressBar">
            <Setter Property="Height"           Value="8"/>
            <Setter Property="Foreground"       Value="{StaticResource Accent}"/>
            <Setter Property="Background"       Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid>
                            <Border Background="{TemplateBinding Background}" CornerRadius="4"/>
                            <Border x:Name="PART_Track"/>
                            <Border x:Name="PART_Indicator"
                                    Background="{TemplateBinding Foreground}"
                                    CornerRadius="4"
                                    HorizontalAlignment="Left"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Application.Resources>
</Application>
