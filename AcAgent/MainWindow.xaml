<Window x:Class="AcAgent.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AcAgent — Assetto Corsa Launcher"
        Height="700" Width="1120"
        MinHeight="620" MinWidth="960"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgDeep}"
        FontFamily="{StaticResource MainFont}">

    <Grid>
        <!-- ══════════════════════════════════════════════════════════════
             MAIN PANEL  (visible when idle / ready)
        ══════════════════════════════════════════════════════════════ -->
        <Grid x:Name="MainPanel">
            <Grid.RowDefinitions>
                <RowDefinition Height="64"/>   <!-- Title bar -->
                <RowDefinition Height="*"/>    <!-- Content -->
                <RowDefinition Height="46"/>   <!-- Status bar -->
            </Grid.RowDefinitions>

            <!-- ── Title Bar ── -->
            <Border Grid.Row="0" Background="{StaticResource BgPanel}"
                    BorderBrush="{StaticResource Border}" BorderThickness="0,0,0,1">
                <Grid Margin="20,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Logo -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="🏎" FontSize="26" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="AC AGENT" FontSize="16" FontWeight="Bold"
                                       Foreground="{StaticResource Accent}"/>
                            <TextBlock Text="Assetto Corsa Launcher" FontSize="10"
                                       Foreground="{StaticResource TextSecondary}"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- PC Info -->
                    <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock x:Name="PcLabel"
                                   Text="PC: LOADING"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondary}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- Reports button -->
                    <Button Grid.Column="2" x:Name="ReportsBtn"
                            Content="📊  Reports" Click="ReportsBtn_Click"
                            Style="{StaticResource SecondaryButton}"
                            Width="130" Height="36"/>
                </Grid>
            </Border>

            <!-- ── Three-column Content ── -->
            <Grid Grid.Row="1" Margin="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="260"/>  <!-- Cars -->
                    <ColumnDefinition Width="1"/>                 <!-- Divider -->
                    <ColumnDefinition Width="*" MinWidth="260"/>  <!-- Tracks -->
                    <ColumnDefinition Width="1"/>                 <!-- Divider -->
                    <ColumnDefinition Width="300"/>               <!-- Config -->
                </Grid.ColumnDefinitions>

                <!-- ── Cars Column ── -->
                <Grid Grid.Column="0" Margin="16,16,16,16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,12">
                        <TextBlock Text="🚗  SELECT CAR"
                                   Style="{StaticResource SectionHeader}"
                                   FontSize="12" Foreground="{StaticResource AccentGold}"/>
                        <TextBlock x:Name="CarCountLabel"
                                   Text="Loading..." FontSize="11"
                                   Foreground="{StaticResource TextSecondary}"/>
                    </StackPanel>

                    <!-- Search -->
                    <TextBox Grid.Row="1" x:Name="CarSearch"
                             Style="{StaticResource SearchBox}"
                             Tag="🔍  Search cars..."
                             TextChanged="CarSearch_TextChanged"
                             Margin="0,0,0,8"/>

                    <!-- List -->
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <ListBox x:Name="CarList"
                                 Style="{StaticResource DarkListBox}"
                                 SelectionChanged="CarList_SelectionChanged"/>
                    </ScrollViewer>
                </Grid>

                <!-- Vertical Divider -->
                <Rectangle Grid.Column="1" Fill="{StaticResource Border}"/>

                <!-- ── Tracks Column ── -->
                <Grid Grid.Column="2" Margin="16,16,16,16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,12">
                        <TextBlock Text="🏁  SELECT TRACK"
                                   Style="{StaticResource SectionHeader}"
                                   FontSize="12" Foreground="{StaticResource AccentGold}"/>
                        <TextBlock x:Name="TrackCountLabel"
                                   Text="Loading..." FontSize="11"
                                   Foreground="{StaticResource TextSecondary}"/>
                    </StackPanel>

                    <!-- Search -->
                    <TextBox Grid.Row="1" x:Name="TrackSearch"
                             Style="{StaticResource SearchBox}"
                             Tag="🔍  Search tracks..."
                             TextChanged="TrackSearch_TextChanged"
                             Margin="0,0,0,8"/>

                    <!-- Layout label -->
                    <TextBlock Grid.Row="2" x:Name="LayoutLabel"
                               Text="" FontSize="11"
                               Foreground="{StaticResource TextSecondary}"
                               Margin="2,0,0,6"/>

                    <!-- List -->
                    <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
                        <ListBox x:Name="TrackList"
                                 Style="{StaticResource DarkListBox}"
                                 SelectionChanged="TrackList_SelectionChanged"/>
                    </ScrollViewer>
                </Grid>

                <!-- Vertical Divider -->
                <Rectangle Grid.Column="3" Fill="{StaticResource Border}"/>

                <!-- ── Config Column ── -->
                <Grid Grid.Column="4" Margin="20,20,20,20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>   <!-- Header -->
                        <RowDefinition Height="Auto"/>   <!-- Mode -->
                        <RowDefinition Height="Auto"/>   <!-- Duration -->
                        <RowDefinition Height="Auto"/>   <!-- Assists -->
                        <RowDefinition Height="Auto"/>   <!-- Player name -->
                        <RowDefinition Height="Auto"/>   <!-- Game Directory -->
                        <RowDefinition Height="*"/>      <!-- Spacer -->
                        <RowDefinition Height="Auto"/>   <!-- Selection preview -->
                        <RowDefinition Height="Auto"/>   <!-- Launch button -->
                    </Grid.RowDefinitions>

                    <!-- Header -->
                    <TextBlock Grid.Row="0" Text="⚙  SESSION CONFIG"
                               Style="{StaticResource SectionHeader}"
                               FontSize="12" Foreground="{StaticResource AccentGold}"
                               Margin="0,0,0,20"/>

                    <!-- Mode selector -->
                    <StackPanel Grid.Row="1" Margin="0,0,0,18">
                        <TextBlock Text="GAME MODE" Style="{StaticResource SectionHeader}"/>
                        <ComboBox x:Name="ModeCombo" Style="{StaticResource DarkCombo}"
                                  SelectionChanged="ModeCombo_SelectionChanged">
                            <ComboBoxItem Content="🏋  Practice"      Tag="Practice"   IsSelected="True"/>
                            <ComboBoxItem Content="⏱  Hot Lap"        Tag="HotLap"/>
                            <ComboBoxItem Content="🕐  Time Attack"    Tag="TimeAttack"/>
                            <ComboBoxItem Content="💨  Drift"          Tag="Drift"/>
                            <ComboBoxItem Content="🏆  Quick Race"     Tag="QuickRace"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- Duration -->
                    <StackPanel Grid.Row="2" Margin="0,0,0,18">
                        <Grid Margin="0,0,0,6">
                            <TextBlock Text="DURATION" Style="{StaticResource SectionHeader}" HorizontalAlignment="Left"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock x:Name="DurationLabel"
                                           Text="30" FontSize="20" FontWeight="Bold"
                                           Foreground="{StaticResource Accent}"/>
                                <TextBlock Text=" min" FontSize="13"
                                           Foreground="{StaticResource TextSecondary}"
                                           VerticalAlignment="Bottom" Margin="0,0,0,2"/>
                            </StackPanel>
                        </Grid>
                        <Slider x:Name="DurationSlider"
                                Style="{StaticResource DarkSlider}"
                                Minimum="5" Maximum="180" Value="30"
                                TickFrequency="5" IsSnapToTickEnabled="True"
                                ValueChanged="DurationSlider_ValueChanged"/>
                        <Grid Margin="0,4,0,0">
                            <TextBlock Text="5 min" FontSize="10" Foreground="{StaticResource TextSecondary}"/>
                            <TextBlock Text="180 min" FontSize="10" Foreground="{StaticResource TextSecondary}"
                                       HorizontalAlignment="Right"/>
                        </Grid>
                    </StackPanel>

                    <!-- Assists -->
                    <StackPanel Grid.Row="3" Margin="0,0,0,18">
                        <TextBlock Text="ASSISTS" Style="{StaticResource SectionHeader}"/>
                        <ComboBox x:Name="AssistsCombo" Style="{StaticResource DarkCombo}">
                            <ComboBoxItem Content="🎮  Easy (Beginner)"   Tag="Easy"       IsSelected="True"/>
                            <ComboBoxItem Content="⚖  Balanced"           Tag="Balanced"/>
                            <ComboBoxItem Content="🔥  Simulation (None)" Tag="Simulation"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- Player name -->
                    <StackPanel Grid.Row="4" Margin="0,0,0,18">
                        <TextBlock Text="DRIVER NAME" Style="{StaticResource SectionHeader}"/>
                        <TextBox x:Name="DriverNameBox"
                                 Style="{StaticResource SearchBox}"
                                 Tag="Your name..."/>
                    </StackPanel>

                    <!-- Game Directory -->
                    <StackPanel Grid.Row="5" Margin="0,0,0,18">
                        <TextBlock Text="GAME DIRECTORY" Style="{StaticResource SectionHeader}"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="AcRootBox"
                                     Grid.Column="0"
                                     Style="{StaticResource SearchBox}"
                                     Tag="AC install path..."
                                     FontSize="10"
                                     TextChanged="AcRootBox_TextChanged"/>
                            <Button Grid.Column="2" x:Name="BrowseAcRootBtn"
                                    Content="📁"
                                    Style="{StaticResource SecondaryButton}"
                                    Width="36" Height="32"
                                    Click="BrowseAcRootBtn_Click"
                                    ToolTip="Browse for Assetto Corsa folder"/>
                        </Grid>
                        <TextBlock x:Name="AcRootStatusLabel"
                                   Text="" FontSize="10" Margin="0,4,0,0"
                                   Foreground="{StaticResource TextSecondary}"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>

                    <!-- Selection preview card -->
                    <Border Grid.Row="7" Background="{StaticResource BgCard}"
                            CornerRadius="8" Padding="14,12" Margin="0,0,0,12">
                        <StackPanel>
                            <TextBlock Text="SELECTED SESSION" Style="{StaticResource SectionHeader}"
                                       Margin="0,0,0,8"/>
                            <TextBlock x:Name="SelectedCarLabel"
                                       Text="Car: — none —" FontSize="12"
                                       Foreground="{StaticResource TextPrimary}"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock x:Name="SelectedTrackLabel"
                                       Text="Track: — none —" FontSize="12"
                                       Foreground="{StaticResource TextPrimary}"
                                       Margin="0,4,0,0"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock x:Name="SelectedSummaryLabel"
                                       Text="" FontSize="11"
                                       Foreground="{StaticResource TextSecondary}"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Launch button -->
                    <Button Grid.Row="8" x:Name="LaunchBtn"
                            Content="🚀  LAUNCH RACE"
                            Style="{StaticResource LaunchButton}"
                            IsEnabled="True"
                            Click="LaunchBtn_Click"/>
                </Grid>
            </Grid>

            <!-- ── Status Bar ── -->
            <Border Grid.Row="2" Background="{StaticResource BgPanel}"
                    BorderBrush="{StaticResource Border}" BorderThickness="0,1,0,0">
                <Grid Margin="20,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Ellipse x:Name="StatusDot" Width="8" Height="8"
                             Fill="{StaticResource Success}"
                             VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock x:Name="StatusLabel" Grid.Column="1"
                               Text="Ready — configure session and click Launch Race"
                               FontSize="12" Foreground="{StaticResource TextSecondary}"
                               VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="2"
                               Text="AcAgent v1.0"
                               FontSize="11" Foreground="{StaticResource Border}"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </Grid>

        <!-- ══════════════════════════════════════════════════════════════
             SESSION OVERLAY  (visible while game is running)
        ══════════════════════════════════════════════════════════════ -->
        <Grid x:Name="SessionOverlay" Visibility="Collapsed"
              Background="{StaticResource BgDeep}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                        Width="520">

                <!-- Status pill -->
                <Border Background="#33FF4757" CornerRadius="20"
                        Padding="18,6" HorizontalAlignment="Center" Margin="0,0,0,30">
                    <TextBlock Text="● SESSION ACTIVE" FontSize="11" FontWeight="Bold"
                               Foreground="{StaticResource Accent}"/>
                </Border>

                <!-- Car @ Track -->
                <TextBlock x:Name="SessionInfoLabel"
                           Text="ferrari_458 @ monza"
                           FontSize="26" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimary}"
                           HorizontalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           Margin="0,0,0,6"/>

                <TextBlock x:Name="SessionModeLabel"
                           Text="Practice"
                           FontSize="14" Foreground="{StaticResource TextSecondary}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,40"/>

                <!-- Big countdown -->
                <TextBlock x:Name="CountdownLabel"
                           Text="30:00"
                           FontSize="72" FontWeight="Bold"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,8"/>
                <TextBlock x:Name="CountdownSubLabel"
                           Text="remaining"
                           FontSize="14" Foreground="{StaticResource TextSecondary}"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,28"/>

                <!-- Progress bar -->
                <ProgressBar x:Name="SessionProgress"
                             Style="{StaticResource TimerBar}"
                             Minimum="0" Maximum="100" Value="0"
                             Margin="0,0,0,40"/>

                <!-- End session button -->
                <Button x:Name="EndSessionBtn"
                        Content="⏹  End Session Early"
                        Style="{StaticResource DangerButton}"
                        Click="EndSessionBtn_Click"
                        Width="240" HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- ══════════════════════════════════════════════════════════════
             COMPLETE OVERLAY  (shown after session ends)
        ══════════════════════════════════════════════════════════════ -->
        <Grid x:Name="CompleteOverlay" Visibility="Collapsed"
              Background="{StaticResource BgDeep}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                        Width="520">

                <!-- Success badge -->
                <Border Background="#332ED573" CornerRadius="20"
                        Padding="18,6" HorizontalAlignment="Center" Margin="0,0,0,24">
                    <TextBlock x:Name="CompleteBadge"
                               Text="✓ SESSION COMPLETE"
                               FontSize="11" FontWeight="Bold"
                               Foreground="{StaticResource Success}"
/>
                </Border>

                <TextBlock x:Name="CompleteCarTrack"
                           Text=""
                           FontSize="22" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimary}"
                           HorizontalAlignment="Center" Margin="0,0,0,24"
                           TextTrimming="CharacterEllipsis"/>

                <!-- Stats grid -->
                <Border Background="{StaticResource BgCard}" CornerRadius="12"
                        Padding="30,20" Margin="0,0,0,32">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                            <TextBlock x:Name="StatDuration"
                                       Text="0.0" FontSize="32" FontWeight="Bold"
                                       Foreground="{StaticResource Accent}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="minutes played" FontSize="11"
                                       Foreground="{StaticResource TextSecondary}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                            <TextBlock x:Name="StatMode"
                                       Text="Practice" FontSize="22" FontWeight="Bold"
                                       Foreground="{StaticResource AccentGold}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="mode" FontSize="11"
                                       Foreground="{StaticResource TextSecondary}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                            <TextBlock x:Name="StatEnded"
                                       Text="Timer" FontSize="22" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimary}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="ended by" FontSize="11"
                                       Foreground="{StaticResource TextSecondary}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Action buttons -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" x:Name="ExportExcelBtn"
                            Content="📊  Export to Excel"
                            Style="{StaticResource SecondaryButton}"
                            Click="ExportExcelBtn_Click"/>
                    <Button Grid.Column="2" x:Name="NewSessionBtn"
                            Content="🔄  New Session"
                            Style="{StaticResource LaunchButton}"
                            Click="NewSessionBtn_Click"/>
                </Grid>

                <TextBlock x:Name="ExportStatusLabel"
                           Text="" FontSize="11"
                           Foreground="{StaticResource Success}"
                           HorizontalAlignment="Center"
                           Margin="0,14,0,0"/>
            </StackPanel>
        </Grid>

    </Grid>
</Window>
